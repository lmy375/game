    "n_cut_intro": {
      "id": "n_cut_intro",
      "kind": "cutscene",
      "next": "n_battle_1",
      "lines": [
        { "speaker": "旁白", "glyph": "", "text": "边境的哨站燃起了狼烟。三名学徒受命前去清剿来犯的敌兵。" },
        { "speaker": "风术士", "glyph": "风", "text": "敌人散在前方。先用狂风把他们聚到一处。" },
        { "speaker": "火法师", "glyph": "火", "text": "聚好了，我一发十字火焰就能全收。" }
      ]
    },
    "n_battle_1": {
      "id": "n_battle_1",
      "kind": "battle",
      "next": "n_result_1",
      "levelId": "level_001"
    },
    "n_result_1": {
      "id": "n_result_1",
