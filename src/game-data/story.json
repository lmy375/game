      "next": "n_cut_mid"
    },
    "n_cut_mid": {
      "id": "n_cut_mid",
      "kind": "cutscene",
      "next": "n_battle_2",
      "lines": [
        { "speaker": "旁白", "glyph": "", "text": "首战告捷。短暂的休整后，更密集的敌阵出现在峡谷另一端。" },
        { "speaker": "枪兵", "glyph": "枪", "text": "我练成贯穿射击了——把他们排成一列，一击就能洞穿数人。" },
        { "speaker": "风术士", "glyph": "风", "text": "交给我，横向推击能把他们推成整齐的一排。" }
      ]
    },
    "n_battle_2": {
      "id": "n_battle_2",
