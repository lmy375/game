    "n_ending": {
      "id": "n_ending",
      "kind": "ending",
      "next": null,
      "title": "Demo 通关",
      "lines": [
        "峡谷恢复了平静。学徒们在实战中变强，也学会了彼此配合的阵形之术。",
        "更远的战场仍在等待——但那是另一段故事了。",
        "感谢游玩本 Demo。"
      ]
    }
